{
  "name": "vdx-installer",
  "version": "0.1.0",
  "private": true,
  "description": "Samsung VDX Installer — Electron one-installer for VDX apps",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "out/main/electron-main.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:no-hardcoded-source": "tsx scripts/check-no-hardcoded-source.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\" \"test/**/*.{ts,tsx,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:dev-keys": "tsx scripts/generate-dev-keys.ts",
    "gen:fixture": "tsx scripts/make-fixture-vdxpkg.ts",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview"
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.5.0",
    "autoprefixer": "^10.5.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "memfs": "^4.9.0",
    "postcss": "^8.5.13",
    "prettier": "^3.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0",
    "yazl": "^2.5.1",
    "zustand": "^5.0.12"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "minimatch": "^9.0.4",
    "yauzl": "^3.1.3",
    "zod": "^3.23.0"
  }
}
